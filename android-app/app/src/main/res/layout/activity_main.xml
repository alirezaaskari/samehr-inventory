<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp" android:layoutDirection="rtl">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="مدیریت موجودی سامهر" android:textSize="24sp" android:textStyle="bold"/>
    <LinearLayout android:id="@+id/loginPanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <EditText android:id="@+id/siteUrl" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="https://samehrstore.ir" android:inputType="textUri" android:layoutDirection="ltr"/>
        <EditText android:id="@+id/username" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="نام کاربری" android:layoutDirection="ltr"/>
        <EditText android:id="@+id/appPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Application Password" android:inputType="textPassword" android:layoutDirection="ltr"/>
        <Button android:id="@+id/loginButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ورود"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/contentPanel" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
        <TextView android:id="@+id/summary" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="8dp" android:textSize="16sp"/>
        <EditText android:id="@+id/search" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="جستجوی نام یا کد محصول"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/searchButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="جستجو"/>
            <Button android:id="@+id/lowButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="کم‌موجود"/>
            <Button android:id="@+id/logoutButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="خروج"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/products" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
        <ProgressBar android:id="@+id/progress" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center"/>
    </LinearLayout>
</LinearLayout>
